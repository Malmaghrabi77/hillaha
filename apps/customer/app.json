{
  "expo": {
    "name": "حلّها",
    "slug": "customer",
    "owner": "malmaghrabi77",
    "scheme": "customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/halha-icon-1024.png",
    "splash": {
      "image": "./assets/halha-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFF"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {}
      ],
      "expo-secure-store"
    ],
    "android": {
      "package": "com.halha.customer",
      "config": {
        "googleMaps": {
          "apiKey": "GOOGLE_MAPS_API_KEY_CUSTOMER"
        }
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.halha.customer",
      "infoPlist": {
        "NSFaceIDUsageDescription": "استخدم Face ID لتسجيل الدخول بشكل أسرع وأكثر أماناً"
      }
    },
    "newArchEnabled": false,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f5efa312-8b0a-4a79-b35e-0c25776e1873"
      }
    }
  }
}
