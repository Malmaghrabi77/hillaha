{
  "expo": {
    "name": "حلّها",
    "slug": "customer",
    "owner": "malmaghrabi77",
    "scheme": "customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/hillaha-icon-1024.png",
    "splash": {
      "image": "./assets/hillaha-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1E"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {}
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "يحتاج التطبيق للوصول إلى صورك لرفع إثبات التحويل"
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyA3oq4FfPFFZRoVoXUs0aBN6P-3-6AjgnE"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "حلّها يحتاج الوصول لموقعك لتتبع رحلة التوصيل",
          "locationWhenInUsePermission": "حلّها يحتاج الوصول لموقعك لتتبع رحلة التوصيل"
        }
      ]
    ],
    "android": {
      "package": "com.hillaha.customer",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.hillaha.customer",
      "infoPlist": {
        "NSFaceIDUsageDescription": "استخدم Face ID لتسجيل الدخول بشكل أسرع وأكثر أماناً",
        "NSPhotoLibraryUsageDescription": "يحتاج التطبيق للوصول إلى صورك لرفع إثبات التحويل",
        "NSLocationWhenInUseUsageDescription": "حلّها يحتاج الوصول لموقعك لتتبع رحلة التوصيل",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "حلّها يحتاج الوصول لموقعك لتتبع رحلة التوصيل"
      }
    },
    "newArchEnabled": false,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f5efa312-8b0a-4a79-b35e-0c25776e1873"
      }
    }
  }
}
