{
  "name": "hillaha",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev:customer": "pnpm -C apps/customer start",
    "dev:driver": "pnpm -C apps/driver start",
    "dev:services-worker": "pnpm -C apps/services-worker start",
    "dev:partner": "pnpm -C apps/partner dev",
    "dev:web": "pnpm -C apps/web dev",
    "build:customer": "pnpm -C apps/customer export",
    "build:driver": "pnpm -C apps/driver export",
    "build:services-worker": "pnpm -C apps/services-worker export",
    "build:partner": "pnpm -C apps/partner build",
    "build:web": "pnpm -C apps/web build",
    "build:all": "pnpm build:partner && pnpm build:web",
    "eas:build:android": "pnpm -C apps/customer eas build --platform android --non-interactive",
    "eas:build:ios": "pnpm -C apps/customer eas build --platform ios --non-interactive",
    "eas:build:all": "pnpm eas:build:android && pnpm eas:build:ios",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint -- --fix",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,jsx,json,md}'",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
